# MAES Platform environment template

# Domain and routing
DOMAIN=localhost
API_URL=https://localhost
FRONTEND_URL=https://localhost
USE_LETS_ENCRYPT=false
LETSENCRYPT_STAGING=false
# EMAIL=security@example.com
# PUBLIC_IP=
# CORS_ORIGIN=

# Core runtime
NODE_ENV=production
SIEM_EXPORT_LIMIT=1000
SIEM_RATE_LIMIT=50
POWERSHELL_TIMEOUT=1800000
QUEUE_STALLED_INTERVAL=30000
QUEUE_MAX_STALLED_COUNT=1
ENABLE_DOCKER_LOGS=false

# Required secrets
# Generate with:
#   openssl rand -hex 24  # POSTGRES_PASSWORD / REDIS_PASSWORD
#   openssl rand -hex 32  # JWT_SECRET / SERVICE_AUTH_TOKEN / ENCRYPTION_KEY / CERT_PASSWORD / GRAFANA_PASSWORD
POSTGRES_PASSWORD=
REDIS_PASSWORD=
JWT_SECRET=
SERVICE_AUTH_TOKEN=
ENCRYPTION_KEY=
CERT_PASSWORD=
GRAFANA_PASSWORD=

# Threat Intelligence (optional — enrichment returns empty results without these)
# VIRUSTOTAL_API_KEY=
# ABUSEIPDB_API_KEY=
# SHODAN_API_KEY=
# IPQUALITYSCORE_API_KEY=

# Optional overrides
GRAFANA_USER=admin
# API_COMMAND=node src/index.js
